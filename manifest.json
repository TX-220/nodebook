{
  "manifest_version": 3,
  "name": "NodeBook",
  "version": "2.0.0",
  "description": "Visualize your bookmarks as an interactive mind map with import/export and inline editing",
  "permissions": [
    "bookmarks",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
